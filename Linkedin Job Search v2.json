    {
      "parameters": {
        "jsCode": "// ═══════════════════════════════════════════════════════\n//  CLEANUP expired/referred rows + APPEND new job slots\n// ═══════════════════════════════════════════════════════\n\nconst staticData = $getWorkflowStaticData('global');\nconst newJobs = staticData.newJobsForReferral || [];\nconst now = new Date();\nconst CUTOFF_MS = 72 * 60 * 60 * 1000;\nconst timestamp = now.toISOString();\n\n// ── 1. Read existing referral rows from input ──\nconst existingRows = $input.all().map(i => ({ ...i.json }));\n\n// ── 2. Keep rows that are NOT expired and NOT referred ──\nconst keptRows = existingRows.filter(row => {\n  // Skip empty/header rows\n  if (!row.applyLink && !row.title) return false;\n\n  // If gotReferral is marked → remove\n  if (row.gotReferral && String(row.gotReferral).trim() !== '') return false;\n\n  // If older than 72 hours → remove\n  if (row.timestamp) {\n    const age = now.getTime() - new Date(row.timestamp).getTime();\n    if (age > CUTOFF_MS) return false;\n  }\n\n  return true;\n});\n\n// ── 3. Find which applyLinks already exist (to avoid duplicates) ──\nconst existingLinks = new Set(\n  keptRows.map(r => String(r.applyLink || '').trim()).filter(l => l !== '')\n);\n\n// ── 4. Build 5 slot rows ONLY for genuinely new jobs ──\nconst newSlotRows = [];\nfor (const job of newJobs) {\n  const link = String(job.applyLink || '').trim();\n  if (link === '' || existingLinks.has(link)) continue;\n\n  for (let slot = 1; slot <= 5; slot++) {\n    newSlotRows.push({\n      timestamp,\n      title: job.title,\n      company: job.company,\n      location: job.location,\n      applyLink: job.applyLink,\n      score: job.score,\n      resumeUrl: '',\n      refMsgOverride: '',\n      hmMsgOverride: '',\n      gotReferral: '',\n      slot: String(slot),\n      refFirst: '',\n      refLast: '',\n      refMessage: '',\n      hmFirst: '',\n      hmLast: '',\n      hmMessage: '',\n    });\n  }\n}\n\n// ── 5. Combine: all kept existing rows + all new slot rows ──\nconst allRows = [...keptRows, ...newSlotRows];\n\n// ── 6. Rebuild formulas with correct row numbers ──\n//    Google Sheet row = array index + 2 (row 1 = header)\nconst output = allRows.map((row, idx) => {\n  const R = idx + 2;\n\n  // Referral message: if refFirst is filled → generate message\n  // Priority: refMsgOverride (col H) → Config!B2 (default)\n  // Resume:   resumeUrl (col G) → Config!B4 (default)\nconst refMsg = '=IF(L' + R + '=\"\",\"\",SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(SUBSTITUTE('\n  + 'IF(H' + R + '<>\"\",H' + R + ',Config!B2),'\n  + '\"{{NAME}}\",L' + R + '&\" \"&M' + R + '),'\n  + '\"{{JOB_URL}}\",E' + R + '),'\n  + '\"{{RESUME_URL}}\",IF(G' + R + '<>\"\",G' + R + ',Config!B4)),'\n  + '\"{{COMPANY}}\",C' + R + '))';\n\n  // HM message: same logic with hmMsgOverride (col I) → Config!B3\nconst hmMsg = '=IF(O' + R + '=\"\",\"\",SUBSTITUTE(SUBSTITUTE(SUBSTITUTE(SUBSTITUTE('\n  + 'IF(I' + R + '<>\"\",I' + R + ',Config!B3),'\n  + '\"{{NAME}}\",O' + R + '&\" \"&P' + R + '),'\n  + '\"{{JOB_URL}}\",E' + R + '),'\n  + '\"{{RESUME_URL}}\",IF(G' + R + '<>\"\",G' + R + ',Config!B4)),'\n  + '\"{{COMPANY}}\",C' + R + '))';\n\n  return {\n    json: {\n      timestamp: row.timestamp || '',\n      title: row.title || '',\n      company: row.company || '',\n      location: row.location || '',\n      applyLink: row.applyLink || '',\n      score: row.score != null ? String(row.score) : '',\n      resumeUrl: row.resumeUrl || '',\n      refMsgOverride: row.refMsgOverride || '',\n      hmMsgOverride: row.hmMsgOverride || '',\n      gotReferral: row.gotReferral || '',\n      slot: row.slot ? String(row.slot) : '',\n      refFirst: row.refFirst || '',\n      refLast: row.refLast || '',\n      refMessage: refMsg,\n      hmFirst: row.hmFirst || '',\n      hmLast: row.hmLast || '',\n      hmMessage: hmMsg,\n    }\n  };\n});\n\n// If nothing to write, output a passthrough so the chain doesn't break\nif (output.length === 0) {\n  return [{ json: { _noData: true } }];\n}\n\nreturn output;"
      },
