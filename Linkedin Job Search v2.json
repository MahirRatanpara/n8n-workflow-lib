    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst jobs = staticData.scoredJobs || [];\n\nconst now = new Date();\nconst dateStr = now.toLocaleDateString('en-IN', {\n  month: 'short', day: 'numeric',\n  hour: '2-digit', minute: '2-digit', timeZone: 'Asia/Kolkata'\n});\n\njobs.sort((a, b) => {\n  const scoreA = a.score != null ? a.score : -1;\n  const scoreB = b.score != null ? b.score : -1;\n  return scoreB - scoreA;\n});\n\nlet header = `\\u{1F3AF} *LinkedIn Job Scan*\\n`;\nheader += `\\u{1F4C5} ${dateStr} | *${jobs.length}* New Job${jobs.length > 1 ? 's' : ''}\\n`;\nheader += `\\u{2501}\\u{2501}\\u{2501}\\u{2501}\\u{2501}\\u{2501}\\u{2501}\\u{2501}\\u{2501}\\u{2501}\\u{2501}\\u{2501}\\u{2501}\\u{2501}\\u{2501}\\u{2501}\\u{2501}\\u{2501}\\u{2501}\\u{2501}\\n\\n`;\n\nconst jobBlocks = jobs.map((job, i) => {\n  let block = `\\u{1F4BC} *${job.title}*\\n`;\n  block += `\\u{1F3E2} ${job.company}  \\u{1F4CD} ${job.location}\\n`;\n  if (job.score != null) {\n      function scoreEmoji(s) {\n          if (s >= 80) return '\\u{1F525}';\n          if (s >= 65) return '\\u{2B50}';\n          if (s >= 50) return '\\u{1F7E1}';\n          if (s >= 35) return '\\u{1F7E0}';\n          return '\\u{26AA}';\n      }\n      block += `\\u{1F916} Match Score: *${job.score}/100* ${scoreEmoji(job.score)}\\n`;\n  } else {\n      block += `\\u{1F916} Match Score: _[AI Unavailable]_\\n`;\n  }\n  block += `\\u{1F517} [Apply on LinkedIn](${job.applyLink})\\n\\n`;\n  return block;\n});\n\nconst MAX_LEN = 3800;\nconst messages = [];\nlet currentMsg = header;\n\nfor (const block of jobBlocks) {\n  if ((currentMsg + block).length > MAX_LEN) {\n    messages.push(currentMsg);\n    currentMsg = `\\u{1F3AF} *...continued (${messages.length + 1})*\\n\\n` + block;\n  } else {\n    currentMsg += block;\n  }\n}\n\ncurrentMsg += `\\u{2501}\\u{2501}\\u{2501}\\u{2501}\\u{2501}\\u{2501}\\u{2501}\\u{2501}\\u{2501}\\u{2501}\\u{2501}\\u{2501}\\u{2501}\\u{2501}\\u{2501}\\u{2501}\\u{2501}\\u{2501}\\u{2501}\\u{2501}\\n`;\ncurrentMsg += `\\u{23F0} _Next scan in ~6 hours_`;\nmessages.push(currentMsg);\n\nstaticData.newJobs = [];\nstaticData.scoredJobs = [];\n\nreturn messages.map(msg => ({ json: { message: msg } }));"
      },
