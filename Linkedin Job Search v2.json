      "parameters": {
        "jsCode": "// Capture the new scored jobs before Read Referral Engine replaces pipeline data\nconst staticData = $getWorkflowStaticData('global');\nconst items = $input.all();\n\n// Store the new jobs so the downstream Cleanup node can access them\nstaticData.newJobsForReferral = items.map(i => ({\n  title: i.json.title || '',\n  company: i.json.company || '',\n  location: i.json.location || '',\n  applyLink: i.json.applyLink || '',\n  score: i.json.score != null ? String(i.json.score) : '',\n}));\n\n// Pass items through so Read Referral Engine can trigger\nreturn items;\n"
      },
