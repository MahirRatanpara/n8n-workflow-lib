    {
      "parameters": {
        "jsCode": "// Store new job data for batch AI scoring later\nconst staticData = $getWorkflowStaticData('global');\nif (!staticData.newJobs) staticData.newJobs = [];\n\nconst jobData = $('Modify Job Attributes').item.json;\n\nstaticData.newJobs.push({\n  title: jobData.title || '',\n  company: jobData.company || '',\n  location: jobData.location || '',\n  description: jobData.description || '',\n  jobid: jobData.jobid || '',\n  applyLink: (jobData.applyLink || '').trim()\n});\n\nreturn $input.all();"
      },
      "id": "baa9fd31-08cd-47c1-9405-b0f8dbda7947",
      "name": "Accumulate Raw Job",
      "type": "n8n-nodes-base.code",
